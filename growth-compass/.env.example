# === LLM Provider Configuration ===
# Set ONE of these based on which provider you use:

# Option A: Anthropic (Claude)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Option B: DeepSeek
# Get your key at https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-...

# Option C: OpenAI
# Get your key at https://platform.openai.com
# OPENAI_API_KEY=sk-...

# === Optional overrides ===
# Provider is auto-detected from which API key is set.
# Use these to override:
# GROWTH_COMPASS_PROVIDER=deepseek
# GROWTH_COMPASS_MODEL=deepseek-chat
# GROWTH_COMPASS_BASE_URL=https://your-custom-api.com/v1
